        </mxCell>
        <mxCell id="pa1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Browser&#xa;login form" vertex="1">
          <mxGeometry height="70" width="160" x="20" y="100" as="geometry" />
        </mxCell>
        <mxCell id="pa2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="POST /auth/login&#xa;validateUser() — bcrypt compare" vertex="1">
          <mxGeometry height="70" width="200" x="220" y="100" as="geometry" />
        </mxCell>
        <mxCell id="oa1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Browser&#xa;&#39;Sign in with Google/GitHub&#39;" vertex="1">
          <mxGeometry height="70" width="160" x="20" y="200" as="geometry" />
        </mxCell>
        <mxCell id="oa2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="GET /auth/google|github&#xa;redirect to provider" vertex="1">
          <mxGeometry height="70" width="200" x="220" y="200" as="geometry" />
        </mxCell>
        <mxCell id="oa3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="Google OAuth /&#xa;GitHub OAuth" vertex="1">
          <mxGeometry height="70" width="160" x="460" y="200" as="geometry" />
        </mxCell>
        <mxCell id="oa4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="GET .../callback&#xa;Passport strategy validates" vertex="1">
          <mxGeometry height="70" width="200" x="660" y="200" as="geometry" />
        </mxCell>
        <mxCell id="oa5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="oauthLogin()&#xa;find by providerId → auto-link by email → create if new" vertex="1">
          <mxGeometry height="90" width="240" x="900" y="190" as="geometry" />
        </mxCell>
        <mxCell id="jwtgen" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="login(user) — JWT generation&#xa;payload {sub,email,role}&#xa;signed JWT_SECRET, expiresIn 7d" vertex="1">
          <mxGeometry height="90" width="220" x="1190" y="140" as="geometry" />
        </mxCell>
        <mxCell id="refreshNote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;fontSize=10;" value="Refresh Token — NOT IMPLEMENTED (future)&#xa;single access token only, no rotation" vertex="1">
          <mxGeometry height="50" width="220" x="1190" y="250" as="geometry" />
        </mxCell>
        <mxCell id="respPwd" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Password path:&#xa;JSON { access_token, user }" vertex="1">
          <mxGeometry height="60" width="220" x="1460" y="110" as="geometry" />
        </mxCell>
        <mxCell id="respOauth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="OAuth path: redirect →&#xa;FRONTEND_URL/auth/oauth/callback?token=..." vertex="1">
          <mxGeometry height="60" width="220" x="1460" y="190" as="geometry" />
        </mxCell>
        <mxCell id="browserStore" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Browser stores access_token&#xa;(client-side)" vertex="1">
          <mxGeometry height="60" width="220" x="1460" y="270" as="geometry" />
        </mxCell>
        <mxCell id="pr1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Protected API request&#xa;Authorization: Bearer &lt;token&gt;" vertex="1">
          <mxGeometry height="70" width="220" x="20" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pr2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="JwtAuthGuard&#xa;(Passport AuthGuard &#39;jwt&#39;)" vertex="1">
          <mxGeometry height="70" width="220" x="280" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pr3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="JwtStrategy.validate()&#xa;verify signature + expiry" vertex="1">
          <mxGeometry height="70" width="220" x="540" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pr4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Lookup user by sub&#xa;Redis cache first (TTL 30s)&#xa;miss → PostgreSQL, then warm cache" vertex="1">
          <mxGeometry height="70" width="220" x="800" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pr5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Current User attached&#xa;(req.user) → handler runs" vertex="1">
          <mxGeometry height="60" width="240" x="1060" y="350" as="geometry" />
        </mxCell>
        <mxCell id="pr6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="401 Unauthorized&#xa;bad signature / expired / user deleted" vertex="1">
          <mxGeometry height="60" width="240" x="1060" y="430" as="geometry" />
        </mxCell>
        <mxCell id="logoutNote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;fontSize=10;align=left;" value="Logout = client deletes token locally. No server endpoint exists — JWT is stateless, no blacklist, can&#39;t force-revoke a token before its 7-day expiry." vertex="1">
          <mxGeometry height="60" width="500" x="20" y="480" as="geometry" />
        </mxCell>
        <mxCell id="authNotes" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" value="Architecture Notes — why JWT over server sessions" vertex="1">
          <mxGeometry height="240" width="540" x="1340" y="380" as="geometry" />
        </mxCell>
        <mxCell id="authNotesText" parent="1" style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;verticalAlign=top;" value="• Stateless — no session store needed; any EC2 instance can validate any request independently.&#xa;• Simplifies horizontal scaling — no sticky sessions required for auth; the hot JwtStrategy.validate() lookup is read-through cached in Redis (TTL 30s, fail-open on Redis errors) instead of hitting Postgres every request.&#xa;• Same JWT works for both password and OAuth users — one unified identity payload (sub/email/role) regardless of login method.&#xa;• Trade-off accepted: can&#39;t force-revoke a token before its 7-day expiry (no blacklist) — acceptable at this low-risk, pre-launch stage; refresh-token rotation is a planned hardening step, not yet built." vertex="1">
          <mxGeometry height="195" width="500" x="1360" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ae1" edge="1" parent="1" source="pa1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" target="pa2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae2" edge="1" parent="1" source="pa2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" target="jwtgen" value="(password path)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae3" edge="1" parent="1" source="oa1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" target="oa2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae4" edge="1" parent="1" source="oa2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" target="oa3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
