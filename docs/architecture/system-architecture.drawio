          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae8" edge="1" parent="1" source="jwtgen" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" target="refreshNote">
