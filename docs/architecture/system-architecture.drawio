        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="6. AiProcessor&#xa;separate WORKER_MODE process&#xa;picks up job" vertex="1">
