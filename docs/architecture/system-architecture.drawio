        <mxCell id="g1" value="GitHub&#xa;push / PR to main" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="ci job:&#xa;Lint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="240" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="Build (turbo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g5" value="Typecheck" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g6" value="test job (parallel):&#xa;Backend Tests (Jest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="240" y="260" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g7" value="Landing Tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="440" y="260" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g8" value="e2e job&#xa;(needs ci + test):&#xa;migrations + Playwright" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="780" y="190" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g9" value="CI/CD pipeline green ✓&#xa;NOTE: no deploy step exists in this workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1060" y="190" width="260" height="70" as="geometry" />
        </mxCell>
        <!-- ===== Deployment (manual today) ===== -->
        <mxCell id="manBox" value="Deployment to AWS — MANUAL today (separate from the GitHub Actions workflow above)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="20" y="380" width="1680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="Local:&#xa;docker build&#xa;(apps/api/Dockerfile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="docker push → ECR&#xa;insightstream-api:latest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="240" y="420" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="SSH to EC2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="460" y="420" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="docker-run.sh:&#xa;source secrets from&#xa;SSM Parameter Store" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="630" y="420" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="docker pull image&#xa;from ECR (latest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="850" y="420" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="docker run redis:7-alpine&#xa;+ docker run insightstream-api&#xa;(shared docker network, -p 3001:3001)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1050" y="420" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="Application running&#xa;:3001, behind ALB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1360" y="420" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="plannedNote" value="Planned: CodeBuild + GitHub webhook (provisioned, quota unblocked 2026-07-05 — was 0 concurrent builds, now 15). Would replace steps m1–m3; not yet wired up (business-priority trigger now, not a feasibility one — see PLAN.md). m4–m7 stay the same." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="780" height="60" as="geometry" />
        </mxCell>
        <!-- ===== Current vs Target ===== -->
        <mxCell id="ctBox" value="Cutover status (2026-07-11): Web still parallel-run; API cutover complete (this pipeline produces the live EC2+ALB deploy)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="900" y="600" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ctWeb" value="Vercel (apps/web) → Amplify (live, not cut over)" style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="920" y="635" width="460" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ctApi" value="Railway (apps/api) → EC2 + ALB — live prod (cutover complete, Railway decommissioned)" style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="920" y="660" width="460" height="20" as="geometry" />
        </mxCell>
        <!-- ===== Notes ===== -->
        <mxCell id="deployNotes" value="Notes — why Docker / ECR / EC2 pulls instead of building locally" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1440" y="600" width="440" height="160" as="geometry" />
        </mxCell>
        <mxCell id="deployNotesText" value="• Docker — same image runs in local dev, CI, and EC2; eliminates &quot;works on my machine&quot; drift.&#xa;• ECR — private, region-local registry; EC2 pulls over the AWS network (fast, no public egress) and IAM gates who can push/pull.&#xa;• EC2 pulls a pre-built image rather than building in place — keeps the free-tier t3.micro&#39;s limited CPU/RAM for running the API, not compiling it." style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1460" y="635" width="400" height="115" as="geometry" />
        </mxCell>
        <!-- ===== Edges ===== -->
        <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g1" target="g3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g3" target="g4">
