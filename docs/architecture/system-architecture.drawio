        </mxCell>
        <!-- ===== CI (GitHub Actions, automated) ===== -->
        <mxCell id="ciBox" value="GitHub Actions — &quot;Pipeline&quot; workflow (automated, runs on every push/PR to main)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#9673a6;" vertex="1" parent="1">
