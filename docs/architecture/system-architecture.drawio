          <mxGeometry height="55" width="125" x="775" y="885" as="geometry" />
        </mxCell>
        <mxCell id="fLayerCicd" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#666666;dashed=1;" value="Cross-cutting: CI/CD &amp; Monitoring (applies to web+api+widget — no arrows, see notes)" vertex="1">
