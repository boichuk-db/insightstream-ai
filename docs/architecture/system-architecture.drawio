        <mxCell id="rLS2" edge="1" parent="1" source="eProject" style="edgeStyle=entityRelationEdgeStyle;html=1;fontSize=10;dashed=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;rounded=0;exitX=1;exitY=0.3;" target="eLastSeen" value="(soft FK)">
