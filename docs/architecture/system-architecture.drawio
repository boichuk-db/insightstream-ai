        <!-- ===== Legend ===== -->
        <mxCell id="lgBox" value="Legend" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" vertex="1" parent="1">
