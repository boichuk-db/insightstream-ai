        <mxCell id="de3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g4" target="g5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g1" target="g6">
