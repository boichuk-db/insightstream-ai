          <mxGeometry x="20" y="10" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nsubtitle" value="Pure network/security view — for compute, async processing, monitoring and build pipeline see the AWS Infrastructure tab. eu-north-1 (Stockholm)." style="text;html=1;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1">
