  <diagram id="request-lifecycle" name="Request Lifecycle">
    <mxGraphModel dx="1267" dy="1160" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="600" math="0" shadow="0">
