        <mxCell id="lgTx1" value="AWS Network" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="1674" y="86" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lgSw2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1640" y="118" width="24" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lgTx2" value="Compute (public IP)" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="1674" y="114" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lgSw3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1640" y="146" width="24" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lgTx3" value="Data (private, no public IP)" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="1674" y="142" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lgSw4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1640" y="174" width="24" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lgTx4" value="External / Internet" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="1674" y="170" width="190" height="20" as="geometry" />
        </mxCell>
        <!-- ===== Funnel ===== -->
        <mxCell id="internet" value="Internet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="780" y="90" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="route53" value="Route53&#xa;(planned — no domain registered yet)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="160" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cloudfront" value="CloudFront&#xa;(planned — blocked by verification gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="230" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="vpcBox" value="VPC 10.0.0.0/16" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="500" y="310" width="900" height="430" as="geometry" />
        </mxCell>
        <mxCell id="igw" value="Internet Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="780" y="340" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rtPublic" value="Route Table (public)&#xa;0.0.0.0/0 → IGW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="410" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pubSubnet" value="Public Subnet 10.0.1.0/24 — has route to IGW" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="400" width="630" height="160" as="geometry" />
        </mxCell>
        <mxCell id="alb" value="ALB&#xa;public IP&#xa;SG: in 80,443 from 0.0.0.0/0 / out → EC2 SG:3001" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="760" y="440" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ec2" value="EC2 t3.micro&#xa;public IP&#xa;SG: in 3001 from ALB SG only / out → RDS SG:5432, 443 (Gemini/SSM/ECR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1070" y="440" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="rtPrivate" value="Route Table (private)&#xa;no 0.0.0.0/0 route" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="600" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="privSubnet" value="Private Subnet 10.0.2.0/24 — no internet route" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="730" y="590" width="630" height="120" as="geometry" />
        </mxCell>
        <mxCell id="rds" value="RDS PostgreSQL&#xa;NO public IP&#xa;SG: in 5432 from EC2 SG only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="800" y="630" width="280" height="70" as="geometry" />
        </mxCell>
        <!-- ===== Inbound/Outbound rules table ===== -->
        <mxCell id="rulesBox" value="Security Group Rules (by port)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="20" y="310" width="440" height="260" as="geometry" />
        </mxCell>
        <mxCell id="rulesText" value="Inbound:&#xa;  80, 443 → ALB SG, from 0.0.0.0/0&#xa;  3001 → EC2 SG, from ALB SG only&#xa;  5432 → RDS SG, from EC2 SG only&#xa;&#xa;Outbound:&#xa;  ALB → EC2 SG:3001&#xa;  EC2 → RDS SG:5432, + 443 to internet&#xa;       (Gemini API, SSM, ECR pull)&#xa;  RDS → none (no outbound needed)" style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;verticalAlign=top;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="400" height="210" as="geometry" />
        </mxCell>
        <!-- ===== Why notes ===== -->
        <mxCell id="whyBox" value="Why this shape" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="20" y="590" width="440" height="280" as="geometry" />
        </mxCell>
        <mxCell id="whyText" value="• EC2 is public — this build skips a NAT Gateway (~$32/mo) to stay in the AWS Free Tier; the API SG still only opens 3001 to the ALB SG, not the world.&#xa;• RDS is private — no reason a database should ever take a direct internet connection; only the EC2 SG may reach 5432.&#xa;• ALB exists — terminates HTTP today (HTTPS pending CloudFront), spans 2 AZs for availability, and decouples the public endpoint from EC2&#39;s IP (which changes on stop/start since there&#39;s no Elastic IP).&#xa;• Security Groups are stateful, layered allow-lists (ALB←internet, EC2←ALB-only, RDS←EC2-only) — a request can&#39;t skip a layer even if it knows the next hop&#39;s address." style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="625" width="400" height="230" as="geometry" />
        </mxCell>
        <!-- ===== Edges ===== -->
        <mxCell id="ne1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="internet" target="route53">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ne2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="route53" target="cloudfront">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ne3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="cloudfront" target="igw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ne3b" value="(today, no CloudFront yet)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=0;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="internet" target="alb">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="115" />
              <mxPoint x="600" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ne4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="igw" target="alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ne5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="alb" target="ec2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ne6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ec2" target="rds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="er-diagram" name="Database ER Diagram">
    <mxGraphModel dx="1003" dy="918" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="etitle" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=left;" value="InsightStream AI — Data Model (Entity Relationship Diagram)" vertex="1">
          <mxGeometry height="30" width="900" x="20" y="10" as="geometry" />
        </mxCell>
        <mxCell id="esubtitle" parent="1" style="text;html=1;fontSize=11;fontStyle=2;align=left;" value="Verified against packages/database/src/entities 2026-07-05 — 10 real entities. Columns trimmed to PK/FK/key business fields; see source for full list." vertex="1">
          <mxGeometry height="20" width="1300" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="lgBox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fillColor=none;strokeColor=#444444;" value="Legend" vertex="1">
          <mxGeometry height="120" width="260" x="1730" y="95" as="geometry" />
        </mxCell>
        <mxCell id="lgSw1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="" vertex="1">
          <mxGeometry height="16" width="24" x="1750" y="135" as="geometry" />
        </mxCell>
        <mxCell id="lgTx1" parent="1" style="text;html=1;fontSize=12;align=left;" value="Entity (table)" vertex="1">
          <mxGeometry height="20" width="190" x="1784" y="131" as="geometry" />
        </mxCell>
        <mxCell id="lgTx2" parent="1" style="text;html=1;fontSize=10;align=left;" value="— ┤ one    —∞ ┤ many&#xa;dashed = soft FK (uuid column,&#xa;no @ManyToOne relation in code)" vertex="1">
